# AI Arena — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
# All variables are also required in Railway dashboard → Variables.

# Claude API key — console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API key — platform.openai.com → API Keys
OPENAI_API_KEY=sk-your-key-here

# Google Gemini API key — aistudio.google.com → Get API key
GOOGLE_API_KEY=AIza-your-key-here

# Password gate for the web UI — choose any strong password
# If not set, the app runs with no authentication (anyone can use your API keys)
APP_PASSWORD=your-password-here

# Port the server listens on (default: 3000)
PORT=3000
