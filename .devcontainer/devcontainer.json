{
  "name": "AI Arena",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "AI Arena",
      "onAutoForward": "notify"
    }
  },
  "postCreateCommand": "chmod +x scripts/codespace-bootstrap.sh 2>/dev/null || true",
  "postStartCommand": "bash scripts/codespace-bootstrap.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
