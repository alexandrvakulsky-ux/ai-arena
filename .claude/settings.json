{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Bash(gh auth:*)",
      "Skill(schedule)",
      "Skill(schedule:*)",
      "Bash(npm --version)",
      "Bash(npm ls:*)",
      "Bash(claude --version)",
      "Bash(npm start:*)",
      "Bash(wc -l ~/.claude/projects/-workspace/*.jsonl)",
      "Bash(du -sh ~/.claude/projects/-workspace/*.jsonl)",
      "Bash(python3 -m json.tool)",
      "Bash(crontab -l)",
      "Bash(apt list:*)",
      "Read(//etc/**)",
      "Bash(apt-get install:*)",
      "Bash(mkdir -p /workspace/.claude/sessions)",
      "Bash(touch /workspace/.claude/sessions/.gitkeep)",
      "Bash(npm install:*)",
      "Bash(npm list:*)",
      "Bash(npx @modelcontextprotocol/server-puppeteer --version)",
      "Bash(curl -I https://registry.npmjs.org)",
      "Bash(dpkg -l)",
      "Bash(curl -sI \"https://storage.googleapis.com\")",
      "Bash(curl -sI \"https://edgedl.me.gvt1.com\")",
      "Bash(dig +short edgedl.me.gvt1.com)",
      "Bash(ipset test:*)",
      "Bash(curl -sI \"https://edgedl.me.gvt1.com\" --max-time 5)",
      "Bash(dig +short AAAA storage.googleapis.com)",
      "Bash(curl -4 -sI \"https://storage.googleapis.com\" --max-time 5)",
      "Bash(dig +short A storage.googleapis.com)",
      "Bash(apt-cache show:*)",
      "Bash(PUPPETEER_SKIP_DOWNLOAD=true npm install -g @modelcontextprotocol/server-puppeteer)",
      "Read(//usr/local/share/npm-global/lib/node_modules/@modelcontextprotocol/server-puppeteer/node_modules/puppeteer/**)",
      "Read(//usr/local/share/npm-global/lib/node_modules/@modelcontextprotocol/server-puppeteer/node_modules/@puppeteer/**)",
      "Read(//usr/local/share/npm-global/lib/node_modules/@modelcontextprotocol/server-puppeteer/**)",
      "Bash(node -e \":*)",
      "Bash(curl -sI \"https://googlechromelabs.github.io\" --max-time 5)",
      "Bash(curl -s \"https://storage.googleapis.com/chrome-for-testing-public/131.0.6778.204/linux64/chrome-linux64.zip\" --max-time 5 -o /dev/null -w \"%{http_code}\")",
      "Bash(curl -v \"https://storage.googleapis.com/chrome-for-testing-public/131.0.6778.204/linux64/chrome-linux64.zip\" --max-time 10 -o /dev/null)",
      "Read(//home/node/.cache/puppeteer/chrome/linux-131.0.6778.204/chrome-linux64/**)",
      "Bash(sudo apt-get:*)",
      "Bash(ldconfig -p)",
      "Bash(curl -s http://localhost:3000)",
      "Bash(npx puppeteer:*)",
      "Bash(curl -s http://localhost:3000 -o /dev/null -w \"%{http_code}\")",
      "Bash(curl -s --max-time 5 http://localhost:3000/ -o /dev/null -w \"%{http_code}\")",
      "Bash(node -e \"require\\(''''puppeteer''''\\)\")",
      "Read(//usr/local/lib/node_modules/**)",
      "Bash(npx --yes puppeteer --version)",
      "Read(//usr/lib/**)",
      "Read(//usr/bin/**)",
      "Bash(cat /etc/sudoers.d/*)",
      "Bash(cat /etc/apt/sources.list.d/*.list)",
      "Bash(apt-cache search:*)",
      "Bash(apt-get update:*)",
      "Bash(npx playwright:*)",
      "Read(//home/node/.cache/**)",
      "Bash(ldd /home/node/.cache/puppeteer/chrome-headless-shell/linux-146.0.7680.153/chrome-headless-shell-linux64/chrome-headless-shell)"
    ],
    "additionalDirectories": [
      "/home/node/.claude",
      "/home/node/.claude/projects/-workspace/memory",
      "/tmp"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git pull 2>/dev/null || true",
            "statusMessage": "Pulling latest changes..."
          },
          {
            "type": "command",
            "command": "[ ! -f .env ] && echo '{\"systemMessage\": \"WARNING: .env file is missing! Copy your API keys (.env) before running the server. Required: ANTHROPIC_API_KEY, OPENAI_API_KEY, GOOGLE_API_KEY, APP_PASSWORD\"}' || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /workspace/scripts/save-session.js",
            "statusMessage": "Saving session history..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d=''; process.stdin.on('data',c=>d+=c); process.stdin.on('end',()=>{const f=(JSON.parse(d).tool_input||{}).file_path||''; process.stdout.write(f)})\" | { read -r f; [ -n \"$f\" ] && git add \"$f\" && git commit -m \"Auto-save: update $(basename \\\"$f\\\")\" && git push; } 2>/dev/null || true",
            "statusMessage": "Committing and pushing..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /workspace/scripts/save-session.js 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ]
  }
}
